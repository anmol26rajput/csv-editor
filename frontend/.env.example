# =============================================================================
# Sarva frontend — environment variables
# Copy to `.env.local` for local development, or set these in Vercel.
# Only NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.
# =============================================================================

# Backend API base URL (no trailing /api/v1 needed — the client adds it).
# Local:      http://127.0.0.1:8000
# Production: https://your-backend-host.example.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Public site URL — used for canonical links, sitemap.xml, robots.txt, and
# social share cards. Set this to your real Vercel/custom domain in production.
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
