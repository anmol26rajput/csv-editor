{
    "version": "0.0.1",
    "configurations": [
        {
            "name": "frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
            "port": 3000
        },
        {
            "name": "backend",
            "runtimeExecutable": "backend/.venv/bin/python",
            "runtimeArgs": ["backend/manage.py", "runserver", "8000"],
            "port": 8000
        }
    ]
}
