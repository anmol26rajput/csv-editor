# =============================================================================
# Sarva backend — environment variables
# Copy to `.env` for local development, or set these on your production host.
# NEVER commit the real `.env`.
# =============================================================================

# Which settings module to load: config.settings.dev | config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# Django secret key. Generate with:
#   python -c "from secrets import choice; import string; print(''.join(choice(string.ascii_letters+string.digits) for _ in range(60)))"
SECRET_KEY=change-me

# Never True in production.
DEBUG=True

# Comma-separated hostnames the backend answers to (no scheme).
# Production example: api.yourdomain.com,your-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Postgres connection string. Leave empty to use local SQLite.
# Get it from Supabase → Project Settings → Database → Connection string.
# Prefer the "Session pooler" URL (port 5432) — it works with Django migrations;
# URL-encode special characters in the password.
DATABASE_URL=

# SSL for the DB connection. Supabase requires SSL, so keep this True.
DB_SSL_REQUIRE=True

# Absolute frontend origin(s) allowed to call the API and submit forms.
# Production example: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Optional: force HTTPS redirect in production (default True in prod).
# SECURE_SSL_REDIRECT=True
